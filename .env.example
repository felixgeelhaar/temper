# Temper environment configuration. Used by `temper init` defaults and
# the test harness; production config lives in ~/.temper/config.yaml +
# secrets.yaml (chmod 0600).

# LLM provider (claude | openai | ollama). BYOK on the cloud paths.
LLM_PROVIDER=claude
LLM_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-6

# Optional: override the local Ollama URL used by `temper init` probe.
OLLAMA_URL=http://localhost:11434

# Daemon HTTP port + bind address. Bind is locked to 127.0.0.1; do not
# change without also configuring a daemon.auth_token in secrets.yaml.
DAEMON_PORT=7432
DAEMON_BIND=127.0.0.1

# Runner sandbox image. Pinned by SHA in docker/runner-image; override
# only when iterating on the runner image locally.
RUNNER_IMAGE=temper-runner-sandbox:latest
